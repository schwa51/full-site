<!DOCTYPE html>
<html lang="en">
{% set currentsystem = system %}
{% set activeTheme = theme | default("mothership") %}
<head>
<script src="/assets/js/nav-header.js?v=20260706-3" defer></script>
<script src="/assets/js/external-links.js" defer></script>
<link rel="apple-touch-icon" sizes="180x180" href="/static/favicon/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/static/favicon/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/static/favicon/favicon-16x16.png">
<link rel="shortcut icon" href="/static/favicon/favicon.ico">
<link rel="manifest" href="/site.webmanifest">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://use.typekit.net" crossorigin>
<link rel="preconnect" href="https://p.typekit.net" crossorigin>
<link href="/assets/css/mana.css" rel="stylesheet" type="text/css" />
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta charset="UTF-8">
<title>{{ title }}</title>
<link rel="stylesheet" href="https://use.typekit.net/abt0pgb.css">
<link rel="stylesheet" href="/assets/css/style.css">
<link rel="stylesheet" href="/assets/css/nav-header.css?v=20260706-3">

{% if rpg_catalog %}
  <link rel="stylesheet" href="/assets/css/rpg-catalog.css">
{% endif %}

{% if future_games_index %}
  <link rel="stylesheet" href="/assets/css/future-games.css">
{% endif %}

  {% if activeTheme == "main" %}
    <link rel="stylesheet" href="/assets/css/theme-main.css">
  {% elif activeTheme == "tor" %}
    <link rel="stylesheet" href="/assets/css/theme-tor.css">
  {% elif activeTheme == "pirateborg" %}
    <link rel="stylesheet" href="/assets/css/theme-pirateborg.css">
  {% elif activeTheme == "wildsea" %}
    <link rel="stylesheet" href="/assets/css/theme-wildsea.css">
    {% elif activeTheme == "paranoia" %}
    <link rel="stylesheet" href="/assets/css/theme-paranoia.css?v=20260707-6">
    {% elif activeTheme == "mothership" %}
    <link rel="stylesheet" href="/assets/css/theme-mothership.css">
    {% elif activeTheme == "timewatch" %}
    <link rel="stylesheet" href="/assets/css/theme-timewatch.css">
    {% elif activeTheme == "mythic" %}
    <link rel="stylesheet" href="/assets/css/theme-mythic.css">
    {% elif activeTheme == "dolmenwood" %}
    <link rel="stylesheet" href="/assets/css/theme-dolmenwood.css">
    {% elif activeTheme == "halloween" %}
    <link rel="stylesheet" href="/assets/css/theme-halloween.css">
    {% elif activeTheme == "ten-candles" %}
    <link rel="stylesheet" href="/assets/css/theme-ten-candles.css">
    {% elif activeTheme == "shadowdark" %}
    <link rel="stylesheet" href="/assets/css/theme-shadowdark.css">
    {% elif activeTheme == "the-dare" %}
    <link rel="stylesheet" href="/assets/css/theme-the-dare.css">
    {% elif activeTheme == "dread" %}
    <link rel="stylesheet" href="/assets/css/theme-dread.css">
    {% elif activeTheme == "brindlewood" %}
    <link rel="stylesheet" href="/assets/css/theme-brindlewood.css">
    {% elif activeTheme == "test" %}
    <link rel="stylesheet" href="/assets/css/theme-test.css">
      {% elif activeTheme == "christmas" %}
    <link rel="stylesheet" href="/assets/css/theme-christmas.css?v=20260712-2">
  {% endif %}
<link rel="stylesheet" href="/assets/css/dark-mode.css">
</head>

{% set navTree = collections.all | eleventyNavigation %}
{# Choose the correct navigation tree #}
{% if page.url == '/' %}
  {% set navTree = collections.global_navigation | eleventyNavigation %}
{% elif page.data.system %}
  {% set navTree = collections[page.data.system + '_navigation'] | eleventyNavigation %}
{% else %}
  {% set navTree = collections.global_navigation | eleventyNavigation %}
{% endif %}

<body class="{{ activeTheme }}{% if future_game %} future-game-brief{% endif %}{% if no_heading_border %} no-heading-border{% endif %}">
   {% include "components/header.njk" %}         
  <div class="layout-wrapper">
  <main class="page-content">
  {% if security_clearance %}
  <div class="security-clearance-warning" data-clearance="{{ security_clearance }}" role="note" aria-label="Security clearance {{ security_clearance }}. Authorized personnel only.">
    <span>Security Clearance</span>
    <strong>{{ security_clearance }}</strong>
    <span>Authorized Personnel Only</span>
  </div>
  {% endif %}
  {% if hide_title_block != true %}
  {% include "components/title-block.njk" %}
  {% endif %}
  {% if gm %}
  {% gm %}{{ content | safe }}{% endgm %}
{% else %}
  {{ content | safe }}
{% endif %}

  {# AUTO-APPEND related links for session pages #}
  {% if type == "sessions"  %}
    {% include "components/session-related.njk" %}
  {% endif %}
</main>


  </div>

</body>
</html>
