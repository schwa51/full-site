---
title: RPG Library
layout: layout.njk
rpg_catalog: true
hide_title_block: true
no_heading_border: true
eleventyNavigation:
  key: RPG Library
  order: 20
---

<div class="rpg-catalog">
  <header class="rpg-catalog__header">
    <p class="rpg-catalog__eyebrow">From the shelves</p>
    <h1>RPG Library</h1>
    <p>A collection of some of tabletop roleplaying games I have.</p>
  </header>

  <form class="rpg-filters" id="rpg-filters">
    <label>
      <span>Genre / Setting</span>
      <select id="rpg-genre">
        <option value="">All genres</option>
      </select>
    </label>
    <label>
      <span>Rules Engine</span>
      <select id="rpg-engine">
        <option value="">All rules engines</option>
      </select>
    </label>
    <label>
      <span>Dice Used</span>
      <select id="rpg-dice">
        <option value="">All dice</option>
      </select>
    </label>
    <p class="rpg-results" aria-live="polite"><span id="rpg-result-count">{{ rpgGames | length }}</span> games</p>
  </form>

  <div class="rpg-grid" id="rpg-grid">
    {% for game in rpgGames %}
      <a
        class="rpg-card"
        href="/vault/games/{{ game.slug }}/"
        data-genres="{{ game.genreSetting | join('|') }}"
        data-engines="{{ game.rulesEngine | join('|') }}"
        data-dice="{{ game.diceUsed | join('|') }}"
      >
        <div class="rpg-card__body">
          <h2>{{ game.title }}</h2>
          <p class="rpg-card__description">{{ game.description }}</p>
          <dl class="rpg-meta">
            <div><dt>Genre / Setting</dt><dd>{{ game.genreSetting | join(', ') or '—' }}</dd></div>
            <div><dt>Tone / Themes</dt><dd>{{ game.toneThemes | join(', ') or '—' }}</dd></div>
            <div><dt>Premise / Tags</dt><dd>{{ game.premiseTags | join(', ') or '—' }}</dd></div>
            <div><dt>Rules Engine</dt><dd>{{ game.rulesEngine | join(', ') or '—' }}</dd></div>
            <div><dt>Core Mechanics</dt><dd>{{ game.coreMechanics or '—' }}</dd></div>
            <div><dt>Dice Used</dt><dd>{{ game.diceUsed | join(', ') or 'None' }}</dd></div>
          </dl>
        </div>
        <span class="rpg-card__cta">View game <span aria-hidden="true">→</span></span>
      </a>
    {% endfor %}
  </div>
  <p class="rpg-empty" id="rpg-empty" hidden>No games match those filters.</p>
</div>

<script>
  (() => {
    const genre = document.getElementById('rpg-genre');
    const engine = document.getElementById('rpg-engine');
    const dice = document.getElementById('rpg-dice');
    const cards = [...document.querySelectorAll('.rpg-card')];
    const count = document.getElementById('rpg-result-count');
    const empty = document.getElementById('rpg-empty');

    function valuesFrom(dataKey) {
      return [...new Set(cards.flatMap(card =>
        (card.dataset[dataKey] || '').split('|').filter(Boolean)
      ))].sort((a, b) => a.localeCompare(b));
    }

    function addOptions(select, values) {
      values.forEach(value => select.add(new Option(value, value)));
    }

    function includesValue(card, dataKey, selectedValue) {
      if (!selectedValue) return true;
      return (card.dataset[dataKey] || '').split('|').includes(selectedValue);
    }

    function update() {
      let visible = 0;
      cards.forEach(card => {
        const show =
          includesValue(card, 'genres', genre.value) &&
          includesValue(card, 'engines', engine.value) &&
          includesValue(card, 'dice', dice.value);
        if (show) {
          card.removeAttribute('hidden');
          card.style.removeProperty('display');
        } else {
          card.setAttribute('hidden', '');
          card.style.setProperty('display', 'none', 'important');
        }
        if (show) visible += 1;
      });
      count.textContent = visible;
      empty.hidden = visible !== 0;
    }

    addOptions(genre, valuesFrom('genres'));
    addOptions(engine, valuesFrom('engines'));
    addOptions(dice, valuesFrom('dice'));

    [genre, engine, dice].forEach(select => {
      select.addEventListener('change', update);
    });
  })();
</script>
