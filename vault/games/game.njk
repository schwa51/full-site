---
layout: layout.njk
theme: mothership
rpg_catalog: true
hide_title_block: true
no_heading_border: true
pagination:
  data: rpgGames
  size: 1
  alias: game
  addAllPagesToCollections: false
permalink: "vault/games/{{ game.slug }}/index.html"
eleventyComputed:
  title: "{{ game.title }}"
---

<article class="game-page">
  <nav class="game-page__back" aria-label="Breadcrumb">
    <a href="/vault/games/">← All games</a>
  </nav>

  <header class="game-page__header">
    <p class="rpg-catalog__eyebrow">Game profile</p>
    <h1>{{ game.title }}</h1>
    <p class="game-page__description">{{ game.description }}</p>
    {% if game.systemUrl %}
      <a class="game-page__system-link" href="{{ game.systemUrl }}">Visit the dedicated {{ game.title }} page <span aria-hidden="true">→</span></a>
    {% endif %}
  </header>

  <dl class="game-page__details">
    <div><dt>Author</dt><dd>{{ game.author or '—' }}</dd></div>
    <div><dt>Publisher</dt><dd>{{ game.publisher | join(', ') or '—' }}</dd></div>
    <div><dt>Minimum Players</dt><dd>{% if game.minimumPlayers != null %}{{ game.minimumPlayers }}{% else %}—{% endif %}</dd></div>
    <div><dt>Maximum Players</dt><dd>{% if game.maximumPlayers != null %}{{ game.maximumPlayers }}{% else %}—{% endif %}</dd></div>
    <div><dt>Genre / Setting</dt><dd>{{ game.genreSetting | join(', ') or '—' }}</dd></div>
    <div><dt>Tone / Themes</dt><dd>{{ game.toneThemes | join(', ') or '—' }}</dd></div>
    <div><dt>Premise / Tags</dt><dd>{{ game.premiseTags | join(', ') or '—' }}</dd></div>
    <div><dt>Rules Weight</dt><dd>{{ game.rulesWeight or '—' }}</dd></div>
    <div><dt>Licensed Setting</dt><dd>{{ game.licensedSetting | join(', ') or '—' }}</dd></div>
    <div><dt>Rules Engine</dt><dd>{{ game.rulesEngine | join(', ') or '—' }}</dd></div>
    <div><dt>Core Resolution</dt><dd>{{ game.coreResolution | join(', ') or '—' }}</dd></div>
    <div><dt>Core Mechanics</dt><dd>{{ game.coreMechanics or '—' }}</dd></div>
    <div><dt>Dice Used</dt><dd>{{ game.diceUsed | join(', ') or 'None' }}</dd></div>
    <div><dt>GM Required</dt><dd>{{ 'Yes' if game.gmRequired else 'No' }}</dd></div>
    <div><dt>GMless</dt><dd>{{ 'Yes' if game.gmless else 'No' }}</dd></div>
    <div><dt>Solo Supported</dt><dd>{{ 'Yes' if game.soloSupported else 'No' }}</dd></div>
    <div><dt>Display on Website</dt><dd>{{ 'Yes' if game.displayOnWebsite else 'No' }}</dd></div>
  </dl>
</article>
