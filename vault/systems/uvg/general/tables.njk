<section class="uvg-tables" aria-label="Rolling tables">
  <article class="uvg-table-card" data-uvg-hero-roller aria-labelledby="hero-table-heading">
    <header class="uvg-table-card__header">
      <div>
        <h2 id="hero-table-heading">Who Is This Hero?</h2>
        <p>Create a background for your player character.</p>
      </div>
      <button class="uvg-button uvg-button--primary" type="button" data-roll-all aria-label="Roll all three d50s">
        Roll all
      </button>
    </header>

    <div class="uvg-results" aria-label="Who Is This Hero results">
      <article class="uvg-result" data-result-card="identity">
        <p class="uvg-result__label">Who are they?</p>
        <p class="uvg-result__roll" data-result-roll="identity">d50</p>
        <p class="uvg-result__text" data-result-text="identity">—</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="identity" aria-label="Roll the Who are they? column">
          Roll
        </button>
      </article>

      <article class="uvg-result" data-result-card="reason">
        <p class="uvg-result__label">Why are they on the road?</p>
        <p class="uvg-result__roll" data-result-roll="reason">d50</p>
        <p class="uvg-result__text" data-result-text="reason">—</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="reason" aria-label="Roll the Why are they on the road? column">
          Roll
        </button>
      </article>

      <article class="uvg-result" data-result-card="possession">
        <p class="uvg-result__label">What do they bear?</p>
        <p class="uvg-result__roll" data-result-roll="possession">d50</p>
        <p class="uvg-result__text" data-result-text="possession">—</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="possession" aria-label="Roll the What do they bear? column">
          Roll
        </button>
      </article>
    </div>

    <p class="uvg-sr-only" role="status" aria-live="polite" data-roll-announcement></p>

    <details class="uvg-reference">
      <summary>Full table</summary>
      <div class="uvg-reference__scroll">
        <table data-hero-reference-table>
          <caption>Who Is This Hero? complete d50 table</caption>
        </table>
      </div>
    </details>

    <noscript>
      <p class="uvg-noscript">JavaScript is required to roll and display this table.</p>
    </noscript>
  </article>

  <article class="uvg-table-card" data-uvg-name-browser aria-labelledby="name-table-heading">
    <header class="uvg-table-card__header">
      <h2 id="name-table-heading">Do They Need a Name?</h2>
    </header>

    <div class="uvg-table-card__body">
      <div class="uvg-table-control">
        <label for="uvg-name-group">Name group</label>
        <select id="uvg-name-group" data-name-group></select>
      </div>

      <div class="uvg-table-scroll">
        <table class="uvg-data-table" data-name-table>
          <caption class="uvg-sr-only" data-name-caption>Names</caption>
        </table>
      </div>
    </div>

    <noscript>
      <p class="uvg-noscript">JavaScript is required to display the name groups.</p>
    </noscript>
  </article>

  <article class="uvg-table-card" data-uvg-quirk-roller aria-labelledby="quirk-table-heading">
    <header class="uvg-table-card__header">
      <h2 id="quirk-table-heading">Do They Need Another Quirk?</h2>
    </header>

    <div class="uvg-table-card__body">
      <div class="uvg-table-controls">
        <div class="uvg-table-control">
          <label for="uvg-quirk-table">Quirk table</label>
          <select id="uvg-quirk-table" data-quirk-table></select>
        </div>
        <button class="uvg-button uvg-button--primary" type="button" data-roll-quirk>
          Roll d6
        </button>
      </div>

      <div class="uvg-quirk-result" data-quirk-result>
        <p class="uvg-result__roll" data-quirk-roll>d6</p>
        <p class="uvg-result__text" data-quirk-text>—</p>
      </div>
    </div>

    <p class="uvg-sr-only" role="status" aria-live="polite" data-quirk-announcement></p>

    <details class="uvg-reference" data-quirk-reference>
      <summary>Full table</summary>
      <div class="uvg-reference__scroll">
        <table data-quirk-reference-table>
          <caption data-quirk-caption>Additional quirk d6 table</caption>
        </table>
      </div>
    </details>

    <noscript>
      <p class="uvg-noscript">JavaScript is required to roll and display this table.</p>
    </noscript>
  </article>
</section>

