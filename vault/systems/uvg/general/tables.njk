<section class="uvg-tables" aria-labelledby="hero-table-heading">
  <header class="uvg-tables__intro">
    <p class="uvg-tables__eyebrow">Three independent d50 rolls</p>
    <h2 id="hero-table-heading">Who Is This Hero?</h2>
    <p>Roll once on each column to discover who the traveler is, why they are on the road, and what strange thing they bear.</p>
  </header>

  <div class="uvg-roller" data-uvg-hero-roller>
    <div class="uvg-roller__actions">
      <button class="uvg-button uvg-button--primary" type="button" data-roll-all>
        Roll all three d50s
      </button>
    </div>

    <div class="uvg-results" aria-label="Who Is This Hero results">
      <article class="uvg-result" data-result-card="identity">
        <p class="uvg-result__label">Who are they?</p>
        <p class="uvg-result__roll" data-result-roll="identity">d50</p>
        <p class="uvg-result__text" data-result-text="identity">Awaiting a roll.</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="identity">
          Roll this column
        </button>
      </article>

      <article class="uvg-result" data-result-card="reason">
        <p class="uvg-result__label">Why are they on the road?</p>
        <p class="uvg-result__roll" data-result-roll="reason">d50</p>
        <p class="uvg-result__text" data-result-text="reason">Awaiting a roll.</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="reason">
          Roll this column
        </button>
      </article>

      <article class="uvg-result" data-result-card="possession">
        <p class="uvg-result__label">What do they bear?</p>
        <p class="uvg-result__roll" data-result-roll="possession">d50</p>
        <p class="uvg-result__text" data-result-text="possession">Awaiting a roll.</p>
        <button class="uvg-button uvg-button--secondary" type="button" data-roll-column="possession">
          Roll this column
        </button>
      </article>
    </div>

    <p class="uvg-sr-only" role="status" aria-live="polite" data-roll-announcement></p>

    <details class="uvg-reference">
      <summary>Show the complete d50 table</summary>
      <div class="uvg-reference__scroll">
        <table data-hero-reference-table>
          <caption>Who Is This Hero? complete d50 table</caption>
        </table>
      </div>
    </details>

    <noscript>
      <p class="uvg-noscript">JavaScript is required to roll and display this table.</p>
    </noscript>
  </div>
</section>

