---
title: Important Items for Paranoia
layout: layout.njk
type: items
publish: true
system: paranoia
theme: christmas
security_clearance: RED
no_heading_border: true
eleventyNavigation:
  parent: paranoia-system
  key: paranoia-items
  title: Items
  order: 2
---
{% set system = systemSlug or (system | slug) %}
{% set section  = type | slug %}

{% set items = (collections.public_content or [])
  | where("data.systemSlug", system)
  | where("data.section", section)
  | sortBy("data.title") %}

{# self-guards so the index doesn't list itself #}
{% set currentUrl  = page.url or '' %}
{% set currentPath = page.inputPath %}
{% set sectionIndexUrl = "/vault/systems/" + system + "/" + section + "/" %}

<ul class="list">
  {% for it in items %}
    {% set isSelfOrIndex = (it.inputPath == currentPath)
                           or (it.url == currentUrl)
                           or (it.url == sectionIndexUrl)
                           or (it.page and it.page.fileSlug == "index") %}
    {% if not isSelfOrIndex %}
      <li><a href="{{ it.url }}">{{ it.data.title }}</a></li>
    {% endif %}
  {% endfor %}
</ul>
